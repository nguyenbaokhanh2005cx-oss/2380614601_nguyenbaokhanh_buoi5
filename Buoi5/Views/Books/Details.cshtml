@model Buoi5.Models.Book

@{
    ViewData["Title"] = "Chi tiết";
}

<div class="detail-wrapper">
    <div class="detail-image">
        <img src="@Model.Image" alt="@Model.Title" onerror="this.src='@Url.Content("~/images/placeholder-book.svg")'" />
    </div>
    <div class="detail-content">
        <h1 class="detail-title">@Model.Title</h1>
        <div class="detail-meta">
            <div><strong>Tác giả:</strong> @Model.Author</div>
            <div><strong>Chủ đề sách:</strong> @Model.Category?.CategoryName</div>
        </div>
        <div class="detail-price">@Model.Price.ToString("N0") đ</div>
        <p class="detail-description">@Model.Description</p>
        <div class="detail-actions">
            <a class="btn btn-outline-primary" asp-controller="Home" asp-action="Index">Quay lại</a>
            <a class="btn btn-danger" asp-controller="Books" asp-action="Edit" asp-route-id="@Model.Id">Chỉnh sửa</a>
        </div>
    </div>
</div>
