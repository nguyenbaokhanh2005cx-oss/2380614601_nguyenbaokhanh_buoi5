@model Buoi5.Models.Book

@{
    ViewData["Title"] = "Chỉnh sửa";
}

<h2 class="page-title">Chỉnh sửa sách</h2>

<form asp-action="Edit" method="post" class="form-card">
    <input type="hidden" asp-for="Id" />
    <partial name="_Form" model="Model" />
    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
